[Desktop Entry]
Name=nvim
Comment=neovim
Keywords=shell;prompt;command;commandline;cmd;editor;
Icon=io.neovim.nvim
StartupWMClass=io.neovim.nvim
Type=Application
Categories=Development;
Terminal=false
{{- if (eq (env "XDG_CURRENT_DESKTOP") "KDE") }}
Exec=konsole --nofork -e zsh -c 'source ~/.zshrc && nvim %F'
{{- else }}
Exec=ghostty --class=io.neovim.nvim -e /home/linuxbrew/.linuxbrew/bin/nvim %F
{{- end }}
